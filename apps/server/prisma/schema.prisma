// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PROFESSIONAL
  PATIENT
  ADMIN
  MANAGER
}

enum UserStatus {
  PENDING
  COMPLETED
  VERIFIED
  BLOCKED
}

enum AppointmentModality {
  VIRTUAL
  HOME_VISIT
  CLINIC
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum QuestionnaireAnsweredBy {
  PATIENT
  MANAGER
}

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  password      String
  name          String
  role          UserRole   @default(PATIENT)
  status        UserStatus @default(PENDING)
  cpf           String     @default("00000000000")
  emailVerified Boolean    @default(false) @map("email_verified")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  professionalProfile ProfessionalProfile?
  patientProfile      PatientProfile?
  managerProfile      ManagerProfile?

  appointmentsAsDoctor  Appointment[] @relation("DoctorAppointments")
  appointmentsAsPatient Appointment[] @relation("PatientAppointments")

  availability       Availability[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  sessions           Session[]
  answeredQuestionnaires VulnerabilityQuestionnaire[]
  address            Address?

  @@map("users")
}

model ProfessionalProfile {
  id                  String              @id @default(uuid())
  userId              String              @unique @map("user_id")
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  professionalLicense String              @map("professional_license")
  specialities        Speciality[]
  modality            AppointmentModality @default(VIRTUAL)
  bio                 String?             @db.Text
  photoUrl            String?             @map("photo_url")
  socialLinks         Json?               @map("social_links")
  address             String?
  price               Float?
  payments            Json?

  @@map("professional_profiles")
}

model Speciality {
  id                   String                @id @default(uuid())
  name                 String                @unique
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  professionalProfiles ProfessionalProfile[]

  @@map("specialties")
}

model PatientProfile {
  id                     String                      @id @default(uuid())
  userId                 String                      @unique @map("user_id")
  user                   User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone                  String?
  dateOfBirth            DateTime?                   @map("date_of_birth")
  gender                 String?
  address                String?
  questionnaireCompleted Boolean                     @default(false) @map("questionnaire_completed")
  questionnaire          VulnerabilityQuestionnaire?
  createdAt              DateTime                    @default(now()) @map("created_at")
  updatedAt              DateTime                    @updatedAt @map("updated_at")

  @@map("patient_profiles")
}

model VulnerabilityQuestionnaire {
  id               String                  @id @default(uuid())
  patientProfileId String                  @unique @map("patient_profile_id")
  patientProfile   PatientProfile          @relation(fields: [patientProfileId], references: [id], onDelete: Cascade)
  answeredBy       QuestionnaireAnsweredBy @map("answered_by")
  answeredByUserId String                  @map("answered_by_user_id")
  answeredByUser   User                    @relation(fields: [answeredByUserId], references: [id])
  totalScore       Int                     @map("total_score")
  isVulnerable     Boolean                 @default(false) @map("is_vulnerable")
  responseDate     DateTime                @default(now()) @map("response_date")
  responses        Json?

  @@map("vulnerability_questionnaires")
}

model ManagerProfile {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone     String?
  bio       String?  @db.Text
  photoUrl  String?  @map("photo_url")
  address   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("manager_profiles")
}

model Availability {
  id             String @id @default(uuid())
  professionalId String @map("professional_id")
  professional   User   @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  dayOfWeek Int    @map("day_of_week")
  startTime String @map("start_time")
  endTime   String @map("end_time")

  validFrom  DateTime  @default(now()) @map("valid_from")
  validUntil DateTime? @map("valid_until")

  @@map("availability")
}

model Appointment {
  id String @id @default(uuid())

  professionalId String @map("professional_id")
  professional   User   @relation("DoctorAppointments", fields: [professionalId], references: [id])

  patientId String @map("patient_id")
  patient   User   @relation("PatientAppointments", fields: [patientId], references: [id])

  dateTime DateTime            @map("date_time")
  status   AppointmentStatus   @default(PENDING)
  modality AppointmentModality @default(VIRTUAL)
  notes    String?             @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@map("appointments")
}

model PasswordReset {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("password_resets")
}

model Session {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  data      String?  @db.Text

  @@map("sessions")
}

model EmailVerification {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("email_verifications")
}

model Address {
  id         String  @id @default(uuid())
  userId     String  @unique @map("user_id")
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  zipCode    String  @map("zip_code") 
  street     String  
  number     String  
  complement String? 
  district   String
  city       String  
  state      String  

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("addresses")
}
